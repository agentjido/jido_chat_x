# Copy this file to `.env` and fill in real values.
# `test/test_helper.exs` loads `.env` with Dotenvy before tests run.

# Set true to enable tests tagged `:live`.
RUN_LIVE_X_TESTS=false

# X app credentials. The live test currently uses OAuth 1.0a user context through XDK.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Numeric X user id that the authenticated account can DM.
X_TEST_RECIPIENT_ID=

# Optional: used by webhook verification/CRC tests and runtime setup.
# If unset, X_CONSUMER_SECRET is used where the consumer secret is required.
X_WEBHOOK_ID=
